library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity signal_controller is
    Port ( clk : in STD_LOGIC; -- 125MHz
           reset : in STD_LOGIC;
           en: in std_logic;
           f_sin: in unsigned(15 downto 0);
           f_triang: in unsigned(15 downto 0);
           TIEMPO_MUERTO: in unsigned(15 downto 0);
           sine_out : out STD_LOGIC_VECTOR(15 downto 0); -- fsin = 122kHz
           triangle_out : out STD_LOGIC_VECTOR(15 downto 0); -- ftri = 976,56kHz
           digital_signal_A : out STD_LOGIC;
           digital_signal_B : out STD_LOGIC;
           digital_signal_C : out STD_LOGIC;
           digital_signal_D : out STD_LOGIC); -- mf = 8 ; ma = 1
end signal_controller;

 architecture Behavioral of signal_controller is
    signal sine_addr : STD_LOGIC_VECTOR(9 downto 0) := (others => '0');
    signal sine_data : STD_LOGIC_VECTOR(15 downto 0);
    signal triangle_data : STD_LOGIC_VECTOR(15 downto 0);
    signal state : STD_LOGIC := '0';
    signal clk_sin_s : std_logic;
    signal clk_triang_s : std_logic;
    signal digital_signal_s : std_logic;
    
    component div_f_sin is
    Port ( Clk : in STD_LOGIC;
           enable: in std_logic;
           reset : in STD_LOGIC;
           fin_pulsos_sin : in unsigned(15 downto 0);
           clk_sin : out STD_LOGIC);
    end component;
    
    component div_f_striang is
    Port ( Clk : in STD_LOGIC;
           enable: in std_logic;
           reset : in STD_LOGIC;
           fin_pulsos_triang : in unsigned(15 downto 0);
           reloj_triang : out STD_LOGIC);
    end component;
    
    component PWM_TM_signal1 is
    Port ( Clk : in STD_LOGIC;
           reset : in STD_LOGIC;
           PWM_in : in STD_LOGIC;
           DEADTIME_CYCLES: in unsigned (15 downto 0);
           PWM_outA : out STD_LOGIC;
           PWM_outB : out STD_LOGIC;
           PWM_outC : out STD_LOGIC;
           PWM_outD : out STD_LOGIC);
    end component;
      
begin
    -- Instancia de la ROM de la señal senoidal
    sine_rom_inst : entity work.sine_rom
        port map (
            clk => clk,
            en => clk_sin_s,
            addr => sine_addr,
            data_out => sine_data
        );

    -- Instancia del generador de señal triangular
    triangle_gen_inst : entity work.triangle_gen
        port map (
            clk => clk,
            reset => reset,
            en => clk_triang_s,
            triangle_out => triangle_data
        );
    U1 : div_f_sin
    port map (
            clk => clk,
            enable => en,
            reset => reset,
            fin_pulsos_sin => f_sin,
            clk_sin => clk_sin_s
        );
    U2 : div_f_striang
    port map (
            clk => clk,
            reset => reset,
            enable => en,
            fin_pulsos_triang => f_triang,
            reloj_triang => clk_triang_s
        );
    U3 : PWM_TM_signal1
    port map (
         Clk => clk,     
         reset => reset,
         DEADTIME_CYCLES => TIEMPO_MUERTO,
         PWM_in => digital_signal_s,
         PWM_outA => digital_signal_A,
         PWM_outB => digital_signal_B,
         PWM_outC => digital_signal_C,
         PWM_outD => digital_signal_D
    );    
  
    -- Incrementar la dirección de la ROM
    process(clk, reset)
    begin
        if reset = '0' then
            sine_addr <= (others => '0');
        elsif rising_edge(clk) then
            if clk_sin_s = '1' then
                sine_addr <= std_logic_vector(unsigned(sine_addr) + 1);
            end if;
        end if;
    end process;

    -- Conmutación de la señal digital
    process(clk, reset)
    begin
        if reset = '0' then
            state <= '0';
        elsif rising_edge(clk) then
            if state = '0' and signed(sine_data) > signed(triangle_data) then
                state <= '1';
            elsif state = '1' and signed(sine_data) < signed(triangle_data) then
                state <= '0';
            end if;
        end if;
    end process;

    sine_out <= sine_data;
    triangle_out <= triangle_data;
    digital_signal_s <= state;
    
end Behavioral;
