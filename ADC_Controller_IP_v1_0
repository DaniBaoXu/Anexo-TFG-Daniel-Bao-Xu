library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity ADC_Controller_IP_v1_0 is
	generic (
		-- Users to add parameters here

		-- User parameters ends
		-- Do not modify the parameters beyond this line


		-- Parameters of Axi Slave Bus Interface S00_AXI
		C_S00_AXI_DATA_WIDTH	: integer	:= 32;
		C_S00_AXI_ADDR_WIDTH	: integer	:= 4
	);
	port (
		-- Users to add ports here
        CS        : out std_logic;
        SClk      : out std_logic;
        Data1_ADC : in std_logic;
        Data2_ADC : in std_logic;
		-- User ports ends
		-- Do not modify the ports beyond this line


		-- Ports of Axi Slave Bus Interface S00_AXI
		s00_axi_aclk	: in std_logic;
		s00_axi_aresetn	: in std_logic;
		s00_axi_awaddr	: in std_logic_vector(C_S00_AXI_ADDR_WIDTH-1 downto 0);
		s00_axi_awprot	: in std_logic_vector(2 downto 0);
		s00_axi_awvalid	: in std_logic;
		s00_axi_awready	: out std_logic;
		s00_axi_wdata	: in std_logic_vector(C_S00_AXI_DATA_WIDTH-1 downto 0);
		s00_axi_wstrb	: in std_logic_vector((C_S00_AXI_DATA_WIDTH/8)-1 downto 0);
		s00_axi_wvalid	: in std_logic;
		s00_axi_wready	: out std_logic;
		s00_axi_bresp	: out std_logic_vector(1 downto 0);
		s00_axi_bvalid	: out std_logic;
		s00_axi_bready	: in std_logic;
		s00_axi_araddr	: in std_logic_vector(C_S00_AXI_ADDR_WIDTH-1 downto 0);
		s00_axi_arprot	: in std_logic_vector(2 downto 0);
		s00_axi_arvalid	: in std_logic;
		s00_axi_arready	: out std_logic;
		s00_axi_rdata	: out std_logic_vector(C_S00_AXI_DATA_WIDTH-1 downto 0);
		s00_axi_rresp	: out std_logic_vector(1 downto 0);
		s00_axi_rvalid	: out std_logic;
		s00_axi_rready	: in std_logic
	);
end ADC_Controller_IP_v1_0;

architecture arch_imp of ADC_Controller_IP_v1_0 is
    signal Reloj_100kHz_s : std_logic;
    signal DATA1_s        : std_logic_vector(11 downto 0);
    signal DATA2_s        : std_logic_vector(11 downto 0);
    signal DONE_s         : std_logic;
    signal All_DATA       : std_logic_vector(32-1 downto 0);
    signal reset_s        : std_logic;
	-- component declaration
	component ADC_Controller_IP_v1_0_S00_AXI is
		generic (
		C_S_AXI_DATA_WIDTH	: integer	:= 32;
		C_S_AXI_ADDR_WIDTH	: integer	:= 4
		);
		port (
 		reg_0    : in std_logic_vector(C_S_AXI_DATA_WIDTH-1 downto 0);
 		Reset_reg1: out std_logic;
 		
		S_AXI_ACLK	: in std_logic;
		S_AXI_ARESETN	: in std_logic;
		S_AXI_AWADDR	: in std_logic_vector(C_S_AXI_ADDR_WIDTH-1 downto 0);
		S_AXI_AWPROT	: in std_logic_vector(2 downto 0);
		S_AXI_AWVALID	: in std_logic;
		S_AXI_AWREADY	: out std_logic;
		S_AXI_WDATA	: in std_logic_vector(C_S_AXI_DATA_WIDTH-1 downto 0);
		S_AXI_WSTRB	: in std_logic_vector((C_S_AXI_DATA_WIDTH/8)-1 downto 0);
		S_AXI_WVALID	: in std_logic;
		S_AXI_WREADY	: out std_logic;
		S_AXI_BRESP	: out std_logic_vector(1 downto 0);
		S_AXI_BVALID	: out std_logic;
		S_AXI_BREADY	: in std_logic;
		S_AXI_ARADDR	: in std_logic_vector(C_S_AXI_ADDR_WIDTH-1 downto 0);
		S_AXI_ARPROT	: in std_logic_vector(2 downto 0);
		S_AXI_ARVALID	: in std_logic;
		S_AXI_ARREADY	: out std_logic;
		S_AXI_RDATA	: out std_logic_vector(C_S_AXI_DATA_WIDTH-1 downto 0);
		S_AXI_RRESP	: out std_logic_vector(1 downto 0);
		S_AXI_RVALID	: out std_logic;
		S_AXI_RREADY	: in std_logic
		);
	end component ADC_Controller_IP_v1_0_S00_AXI;
	
	--My components
	component AD1RefComp is
	   Port (
       CLK      : in std_logic; -- Reloj de entrada a 100 MHz
       RST      : in std_logic; -- Señal de reset
       SDATA1   : in std_logic; -- Datos seriales del ADC 1
       SDATA2   : in std_logic; -- Datos seriales del ADC 2
       SCLK     : out std_logic; -- Señal de reloj de salida (20 MHz)
       nCS      : out std_logic; -- Señal de selección de chip (chip select)
       DATA1    : out std_logic_vector(11 downto 0); -- Datos paralelos del ADC 1
       DATA2    : out std_logic_vector(11 downto 0); -- Datos paralelos del ADC 2
       START    : in std_logic; -- Señal de inicio
       DONE     : out std_logic -- Señal de finalización
       );
    end component AD1RefComp;
    
    component Conta_Gen_Reloj_100KHz is
       Port ( 
       Clk_in      : in STD_LOGIC;
       reset       : in STD_LOGIC;
       Reloj_100kHz : out STD_LOGIC
       );
    end component Conta_Gen_Reloj_100KHz;

begin
       
     All_DATA <= ("0000" & Data1_s & "0000" & Data2_s) when done_s = '1' else (others => '0');
-- Instantiation of Axi Bus Interface S00_AXI
ADC_Controller_IP_v1_0_S00_AXI_inst : ADC_Controller_IP_v1_0_S00_AXI
	generic map (
		C_S_AXI_DATA_WIDTH	=> C_S00_AXI_DATA_WIDTH,
		C_S_AXI_ADDR_WIDTH	=> C_S00_AXI_ADDR_WIDTH
	)
	port map (
	    reg_0 => All_DATA,
	    Reset_reg1 => reset_s,
	    	
		S_AXI_ACLK	=> s00_axi_aclk,
		S_AXI_ARESETN	=> s00_axi_aresetn,
		S_AXI_AWADDR	=> s00_axi_awaddr,
		S_AXI_AWPROT	=> s00_axi_awprot,
		S_AXI_AWVALID	=> s00_axi_awvalid,
		S_AXI_AWREADY	=> s00_axi_awready,
		S_AXI_WDATA	=> s00_axi_wdata,
		S_AXI_WSTRB	=> s00_axi_wstrb,
		S_AXI_WVALID	=> s00_axi_wvalid,
		S_AXI_WREADY	=> s00_axi_wready,
		S_AXI_BRESP	=> s00_axi_bresp,
		S_AXI_BVALID	=> s00_axi_bvalid,
		S_AXI_BREADY	=> s00_axi_bready,
		S_AXI_ARADDR	=> s00_axi_araddr,
		S_AXI_ARPROT	=> s00_axi_arprot,
		S_AXI_ARVALID	=> s00_axi_arvalid,
		S_AXI_ARREADY	=> s00_axi_arready,
		S_AXI_RDATA	=> s00_axi_rdata,
		S_AXI_RRESP	=> s00_axi_rresp,
		S_AXI_RVALID	=> s00_axi_rvalid,
		S_AXI_RREADY	=> s00_axi_rready
	);

	-- Add user logic here
    AD1RefComp_inst: AD1RefComp
    port map(
        CLK     => s00_axi_aclk,  
        RST     => reset_s,  
        SDATA1  => Data1_ADC,
        SDATA2  => Data2_ADC,
        SCLK    => SClk,  
        nCS     => CS,   
        DATA1   => DATA1_s,                   
        DATA2   => DATA2_s,                  
        START   => Reloj_100kHz_s,                   
        DONE    => DONE_s  
    );
    Conta_Gen_Reloj_100KHz_inst: Conta_Gen_Reloj_100KHz
    port map(
 
        Clk_in  => s00_axi_aclk,   
        reset   => reset_s,    
        Reloj_100kHz => Reloj_100kHz_s 
    );
	-- User logic ends
end arch_imp;
